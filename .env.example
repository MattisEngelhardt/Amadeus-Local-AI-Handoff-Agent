# OpenAI API Key (Required for Whisper Transcription)
OPENAI_API_KEY=your_openai_api_key_here

# Anthropic API Key (Required for Claude Analyzer and Generator)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional: Default output folder for generated projects
# If not specified, voiceforge will look in config.yaml or default to the user's home directory / projects folder.
# DEFAULT_OUTPUT_DIR=C:/Users/your_username/Projects
